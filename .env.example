PORT=4317

# Change these before deploying.
APP_SECRET=change-this-to-a-long-random-secret
APP_INVITE_CODES=dev-invite,demo-2026
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
CORS_ORIGINS=http://localhost:4317,http://127.0.0.1:4317,https://pilipiliwang.github.io
EXTERNAL_API_KEYS=

# Local SQLite file. In Docker this should point at a mounted volume.
SQLITE_PATH=./data/app.sqlite
UPLOAD_STAGING_PATH=./data/pending-uploads

# Optional bootstrap defaults. They can also be set in the Admin page.
RAGFLOW_BASE_URL=http://ragflow:9380
RAGFLOW_API_KEY=
RAGFLOW_DATASET_NAME=web-materials
RAGFLOW_CHAT_NAME=web-materials-assistant
RAGFLOW_REQUEST_TIMEOUT_MS=30000
RAGFLOW_REQUEST_RETRIES=2
RAGFLOW_PARSE_WAIT_MS=45000
RAGFLOW_PARSE_POLL_MS=3000

DIRECT_AI_BASE_URL=https://api.openai.com/v1
DIRECT_AI_API_KEY=
DIRECT_AI_MODEL=
DIRECT_AI_TIMEOUT_MS=60000

WEB_REFRESH_TIMEOUT_MS=30000
URL_FETCH_TIMEOUT_MS=20000
URL_FETCH_TEXT_LIMIT=300000
# Set to false if you do not want blocked URLs to be sent to the reader fallback service.
URL_READER_FALLBACK=true
URL_READER_BASE_URL=https://r.jina.ai/http://r.jina.ai/http://
URL_READER_TIMEOUT_MS=30000
# Windows local development only: use PowerShell as the final reader fetch fallback if Node networking is blocked.
URL_READER_SYSTEM_FETCH=true
URL_READER_MAX_BUFFER=5242880
